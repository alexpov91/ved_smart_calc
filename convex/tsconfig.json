{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "ES2022.Object", "ES2022.SharedMemory"],
    "allowJs": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "module": "ESNext",
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../node_modules/.convex/server.d.ts"],
  "exclude": ["./_generated"]
}
